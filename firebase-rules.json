{
  "rules": {
    ".read": false,
    ".write": false,
    "rooms": {
      "$roomId": {
        ".read": "auth != null",
        ".write": "auth != null && ((!data.exists() && newData.exists() && newData.child('hostId').val() == auth.uid) || (data.exists() && !newData.exists() && (data.child('hostId').val() == auth.uid || data.child('expiresAt').val() < now)))",
        "hostId": {
          ".write": "auth != null && !data.exists() && newData.val() == auth.uid"
        },
        "roomCode": {
          ".write": "auth != null && root.child('rooms').child($roomId).child('hostId').val() == auth.uid"
        },
        "status": {
          ".write": "auth != null && root.child('rooms').child($roomId).child('hostId').val() == auth.uid",
          ".validate": "newData.val() == 'waiting' || newData.val() == 'playing' || newData.val() == 'ended'"
        },
        "gameMode": {
          ".write": "auth != null && root.child('rooms').child($roomId).child('hostId').val() == auth.uid",
          ".validate": "newData.val() == 'coop' || newData.val() == 'versus'"
        },
        "missionMode": {
          ".write": "auth != null && root.child('rooms').child($roomId).child('hostId').val() == auth.uid",
          ".validate": "newData.val() == 'classic' || newData.val() == 'target' || newData.val() == 'boss'"
        },
        "teamScore": {
          ".write": "auth != null && (root.child('rooms').child($roomId).child('hostId').val() == auth.uid || root.child('rooms').child($roomId).child('players').child(auth.uid).exists())",
          ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 99999"
        },
        "targetScore": {
          ".write": "auth != null && root.child('rooms').child($roomId).child('hostId').val() == auth.uid",
          ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 9999"
        },
        "bossHp": {
          ".write": "auth != null && (root.child('rooms').child($roomId).child('hostId').val() == auth.uid || root.child('rooms').child($roomId).child('players').child(auth.uid).exists())",
          ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 999"
        },
        "bossMaxHp": {
          ".write": "auth != null && root.child('rooms').child($roomId).child('hostId').val() == auth.uid",
          ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 999"
        },
        "bossDefeated": {
          ".write": "auth != null && root.child('rooms').child($roomId).child('hostId').val() == auth.uid",
          ".validate": "newData.isBoolean()"
        },
        "completed": {
          ".write": "auth != null && root.child('rooms').child($roomId).child('hostId').val() == auth.uid",
          ".validate": "newData.isBoolean()"
        },
        "endReason": {
          ".write": "auth != null && root.child('rooms').child($roomId).child('hostId').val() == auth.uid",
          ".validate": "newData.isString() && newData.val().length <= 32"
        },
        "level": {
          ".write": "auth != null && root.child('rooms').child($roomId).child('hostId').val() == auth.uid",
          ".validate": "newData.isNumber() && newData.val() >= 1 && newData.val() <= 20"
        },
        "theme": {
          ".write": "auth != null && root.child('rooms').child($roomId).child('hostId').val() == auth.uid",
          ".validate": "newData.isString() && newData.val().length <= 32"
        },
        "duration": {
          ".write": "auth != null && root.child('rooms').child($roomId).child('hostId').val() == auth.uid",
          ".validate": "newData.isNumber() && newData.val() >= 10 && newData.val() <= 300"
        },
        "boardSize": {
          ".write": "auth != null && root.child('rooms').child($roomId).child('hostId').val() == auth.uid",
          ".validate": "newData.isNumber() && newData.val() >= 4 && newData.val() <= 25"
        },
        "currentMole": {
          ".write": "auth != null && root.child('rooms').child($roomId).child('hostId').val() == auth.uid",
          ".validate": "newData.isNumber() && newData.val() >= -1 && newData.val() <= 24"
        },
        "moleKey": {
          ".write": "auth != null && root.child('rooms').child($roomId).child('hostId').val() == auth.uid",
          ".validate": "newData.isString() && newData.val().length <= 100"
        },
        "moleType": {
          ".write": "auth != null && root.child('rooms').child($roomId).child('hostId').val() == auth.uid",
          ".validate": "newData.val() == 'normal' || newData.val() == 'golden' || newData.val() == 'bomb' || newData.val() == 'heart' || newData.val() == 'boss'"
        },
        "moleValue": {
          ".write": "auth != null && root.child('rooms').child($roomId).child('hostId').val() == auth.uid",
          ".validate": "newData.isNumber() && newData.val() >= -10 && newData.val() <= 20"
        },
        "moleSequence": {
          ".write": "auth != null && root.child('rooms').child($roomId).child('hostId').val() == auth.uid",
          ".validate": "newData.isNumber() && newData.val() >= 0"
        },
        "lastHitMoleKey": {
          ".write": "auth != null && (root.child('rooms').child($roomId).child('hostId').val() == auth.uid || root.child('rooms').child($roomId).child('players').child(auth.uid).exists())",
          ".validate": "newData.isString() && newData.val().length <= 100"
        },
        "lastHitBy": {
          ".write": "auth != null && (root.child('rooms').child($roomId).child('hostId').val() == auth.uid || root.child('rooms').child($roomId).child('players').child(auth.uid).exists())",
          ".validate": "newData.isString() && newData.val().length <= 128"
        },
        "moleVisual": {
          ".write": "auth != null && root.child('rooms').child($roomId).child('hostId').val() == auth.uid",
          "type": {
            ".validate": "newData.val() == 'emoji' || newData.val() == 'image'"
          },
          "value": {
            ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 260000"
          },
          "label": {
            ".validate": "newData.isString() && newData.val().length <= 30"
          },
          "$other": {
            ".validate": false
          }
        },
        "hitClaims": {
          ".write": "auth != null && root.child('rooms').child($roomId).child('hostId').val() == auth.uid",
          "$moleKey": {
            ".write": "auth != null && !data.exists() && root.child('rooms').child($roomId).child('players').child(auth.uid).exists()",
            ".validate": "newData.hasChildren(['by', 'at']) && newData.child('by').val() == auth.uid && newData.child('at').isNumber()",
            "by": {
              ".validate": "newData.val() == auth.uid"
            },
            "at": {
              ".validate": "newData.isNumber()"
            },
            "type": {
              ".validate": "newData.isString() && newData.val().length <= 32"
            },
            "$other": {
              ".validate": false
            }
          }
        },
        "startedAt": {
          ".write": "auth != null && root.child('rooms').child($roomId).child('hostId').val() == auth.uid",
          ".validate": "newData.isNumber()"
        },
        "endsAt": {
          ".write": "auth != null && (root.child('rooms').child($roomId).child('hostId').val() == auth.uid || root.child('rooms').child($roomId).child('players').child(auth.uid).exists())",
          ".validate": "newData.isNumber()"
        },
        "createdAt": {
          ".write": "auth != null && root.child('rooms').child($roomId).child('hostId').val() == auth.uid",
          ".validate": "newData.isNumber()"
        },
        "expiresAt": {
          ".write": "auth != null && root.child('rooms').child($roomId).child('hostId').val() == auth.uid",
          ".validate": "newData.isNumber() && newData.val() > now"
        },
        "updatedAt": {
          ".write": "auth != null && (root.child('rooms').child($roomId).child('hostId').val() == auth.uid || root.child('rooms').child($roomId).child('players').child(auth.uid).exists())",
          ".validate": "newData.isNumber()"
        },
        "players": {
          ".indexOn": [
            "score"
          ],
          "$uid": {
            ".read": "auth != null",
            ".write": "auth != null && (auth.uid == $uid || root.child('rooms').child($roomId).child('hostId').val() == auth.uid)",
            "name": {
              ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 16"
            },
            "score": {
              ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 99999"
            },
            "hits": {
              ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 99999"
            },
            "misses": {
              ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 99999"
            },
            "combo": {
              ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 99999"
            },
            "maxCombo": {
              ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 99999"
            },
            "bossHits": {
              ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 99999"
            },
            "active": {
              ".validate": "newData.isBoolean()"
            },
            "joinedAt": {
              ".validate": "newData.isNumber()"
            },
            "lastSeen": {
              ".validate": "newData.isNumber()"
            },
            "$other": {
              ".validate": false
            },
            "kicked": {
              ".validate": "newData.isBoolean()"
            }
          }
        },
        "$other": {
          ".validate": false
        },
        "locked": {
          ".write": "auth != null && root.child('rooms').child($roomId).child('hostId').val() == auth.uid",
          ".validate": "newData.isBoolean()"
        },
        "kickedPlayers": {
          "$uid": {
            ".write": "auth != null && root.child('rooms').child($roomId).child('hostId').val() == auth.uid",
            ".validate": "newData.isBoolean()"
          }
        }
      }
    },
    "leaderboards": {
      ".read": "auth != null",
      "daily": {
        "$period": {
          "records": {
            ".indexOn": [
              "score",
              "timestamp"
            ],
            "$recordId": {
              ".write": "auth != null && newData.child('userId').val() == auth.uid",
              ".validate": "newData.hasChildren(['userId','name','score','mode','level','duration','accuracy','maxCombo','grade','timestamp'])",
              "userId": {
                ".validate": "newData.val() == auth.uid"
              },
              "name": {
                ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 24"
              },
              "score": {
                ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 999999"
              },
              "mode": {
                ".validate": "newData.isString() && newData.val().length <= 40"
              },
              "level": {
                ".validate": "newData.isNumber() && newData.val() >= 1 && newData.val() <= 20"
              },
              "duration": {
                ".validate": "newData.isNumber() && newData.val() >= 1 && newData.val() <= 600"
              },
              "accuracy": {
                ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 100"
              },
              "maxCombo": {
                ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 99999"
              },
              "grade": {
                ".validate": "newData.isString() && newData.val().length <= 4"
              },
              "roomCode": {
                ".validate": "newData.isString() && newData.val().length <= 12"
              },
              "timestamp": {
                ".validate": "newData.isNumber() && newData.val() <= now + 600000"
              },
              "$other": {
                ".validate": false
              }
            }
          }
        }
      },
      "weekly": {
        "$period": {
          "records": {
            ".indexOn": [
              "score",
              "timestamp"
            ],
            "$recordId": {
              ".write": "auth != null && newData.child('userId').val() == auth.uid",
              ".validate": "newData.hasChildren(['userId','name','score','mode','level','duration','accuracy','maxCombo','grade','timestamp'])",
              "userId": {
                ".validate": "newData.val() == auth.uid"
              },
              "name": {
                ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 24"
              },
              "score": {
                ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 999999"
              },
              "mode": {
                ".validate": "newData.isString() && newData.val().length <= 40"
              },
              "level": {
                ".validate": "newData.isNumber() && newData.val() >= 1 && newData.val() <= 20"
              },
              "duration": {
                ".validate": "newData.isNumber() && newData.val() >= 1 && newData.val() <= 600"
              },
              "accuracy": {
                ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 100"
              },
              "maxCombo": {
                ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 99999"
              },
              "grade": {
                ".validate": "newData.isString() && newData.val().length <= 4"
              },
              "roomCode": {
                ".validate": "newData.isString() && newData.val().length <= 12"
              },
              "timestamp": {
                ".validate": "newData.isNumber() && newData.val() <= now + 600000"
              },
              "$other": {
                ".validate": false
              }
            }
          }
        }
      },
      "allTime": {
        "records": {
          ".indexOn": [
            "score",
            "timestamp"
          ],
          "$recordId": {
            ".write": "auth != null && newData.child('userId').val() == auth.uid",
            ".validate": "newData.hasChildren(['userId','name','score','mode','level','duration','accuracy','maxCombo','grade','timestamp'])",
            "userId": {
              ".validate": "newData.val() == auth.uid"
            },
            "name": {
              ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 24"
            },
            "score": {
              ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 999999"
            },
            "mode": {
              ".validate": "newData.isString() && newData.val().length <= 40"
            },
            "level": {
              ".validate": "newData.isNumber() && newData.val() >= 1 && newData.val() <= 20"
            },
            "duration": {
              ".validate": "newData.isNumber() && newData.val() >= 1 && newData.val() <= 600"
            },
            "accuracy": {
              ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 100"
            },
            "maxCombo": {
              ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 99999"
            },
            "grade": {
              ".validate": "newData.isString() && newData.val().length <= 4"
            },
            "roomCode": {
              ".validate": "newData.isString() && newData.val().length <= 12"
            },
            "timestamp": {
              ".validate": "newData.isNumber() && newData.val() <= now + 600000"
            },
            "$other": {
              ".validate": false
            }
          }
        }
      },
      "$other": {
        ".validate": false
      }
    }
  }
}